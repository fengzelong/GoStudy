# 企业应用骨架
APP_NAME=GoStudy Enterprise
APP_ENV=dev
APP_ADDR=:8080
APP_STORAGE=memory
APP_TOKEN_SECRET=change-me
APP_TOKEN_TTL=2h
APP_SHUTDOWN_TIMEOUT=10s

# MySQL 示例
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/go_test
GORM_DSN=root:password@tcp(127.0.0.1:3306)/go_test?charset=utf8&parseTime=True&loc=Local

# Redis 示例
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# RabbitMQ 示例
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
RABBITMQ_QUEUE=GoTestMessage

# Web 与网络示例
GIN_ADDR=:8080
HTTP_ADDR=:8080
RPC_ADDR=127.0.0.1:8080
TCP_ADDR=127.0.0.1:20000
UDP_ADDR=127.0.0.1:30000
GRPC_ADDR=127.0.0.1:50052
GRPC_TRACE_ADDR=:50051
WEBSOCKET_ADDR=127.0.0.1:8080
