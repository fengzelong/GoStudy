{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "调试 Gin 示例",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/gin",
      "env": {
        "GOMODCACHE": "${workspaceFolder}\\.tmp_gomodcache",
        "GOPATH": "${workspaceFolder}\\.tmp_gopath"
      }
    },
    {
      "name": "调试 RPC 服务端",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/rpc/server",
      "env": {
        "GOMODCACHE": "${workspaceFolder}\\.tmp_gomodcache",
        "GOPATH": "${workspaceFolder}\\.tmp_gopath"
      }
    },
    {
      "name": "调试 RPC 客户端",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/rpc/client",
      "env": {
        "GOMODCACHE": "${workspaceFolder}\\.tmp_gomodcache",
        "GOPATH": "${workspaceFolder}\\.tmp_gopath"
      }
    },
    {
      "name": "调试当前 Go 文件",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}",
      "env": {
        "GOMODCACHE": "${workspaceFolder}\\.tmp_gomodcache",
        "GOPATH": "${workspaceFolder}\\.tmp_gopath"
      }
    }
  ]
}
